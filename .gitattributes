# Normalize text files to LF by default
* text=auto eol=lf

# Keep Windows script files in CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Improve diff readability for C#
*.cs diff=csharp

# Unity YAML-based assets should stay text for merge/diff
*.unity text
*.prefab text
*.asset text
*.meta text
*.mat text
*.anim text
*.controller text
